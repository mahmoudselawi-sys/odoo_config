<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Odoo 14 has no manifest "assets" key; extend the backend
         asset bundle via inheritance instead. -->
    <template id="assets_backend"
              name="businesschat_assets_backend"
              inherit_id="web.assets_backend">
        <xpath expr="." position="inside">
            <link rel="stylesheet"
                  type="text/css"
                  href="/whatsapp_invoice_webhook/static/src/css/settings.css"/>
        </xpath>
    </template>

</odoo>
